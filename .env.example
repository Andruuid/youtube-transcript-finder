YOUTUBE_API_KEY=your_youtube_data_api_key
DATABASE_URL="file:./server/prisma/transcripts.dev.db"
REACT_APP_TRANSCRIPT_API_URL=

# Transcript summarization (read by the transcript server — set in server/.env or the shell)
# OPENROUTER_API_KEY=
# SUMMARIZERMODEL_NAME=openai/gpt-4o-mini
# Optional: comma-separated OpenRouter slugs to try if the primary hits 429 / rate limits / overload
# SUMMARIZERMODEL_FALLBACKS=meta-llama/llama-3.3-70b-instruct:free,openai/gpt-4o-mini
# SUMUPSMALL_PROMPT=
# SUMUPLONG_PROMPT=
# Optional OpenRouter rankings headers:
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_TITLE=
